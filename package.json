{
  "name": "pi-darts",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "engines": {
    "node": "^22.18.0 || >=24.12.0"
  },
  "scripts": {
    "dev:board": "npm run dev -w @pi-darts/board",
    "dev:console": "npm run dev -w @pi-darts/console",
    "dev:server": "npm run dev -w @pi-darts/server",
    "build": "npm run build --workspaces --if-present",
    "type-check": "npm run type-check --workspaces --if-present"
  }
}
